<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>100 Bộ Thủ Hán Tự</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Noto+Sans+SC:wght@300;400;500&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1008;
    --paper: #f5f0e8;
    --paper2: #ede7d5;
    --red: #c0392b;
    --gold: #b8860b;
    --gold-light: #d4a017;
    --fade: #8b7355;
    --brush: #2c1810;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'Crimson Pro', 'Noto Sans SC', serif;
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse at 20% 0%, rgba(184,134,11,0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(192,57,43,0.04) 0%, transparent 60%);
  }

  /* HEADER */
  header {
    text-align: center;
    padding: 60px 20px 40px;
    position: relative;
    border-bottom: 1px solid rgba(139,115,85,0.25);
  }
  header::before {
    content: '漢';
    position: absolute;
    font-family: 'Noto Serif SC', serif;
    font-size: 280px;
    color: rgba(184,134,11,0.05);
    top: -40px; left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    letter-spacing: -10px;
  }
  header h1 {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 700;
    letter-spacing: 8px;
    color: var(--brush);
    position: relative;
  }
  header h1 span { color: var(--red); }
  header p {
    margin-top: 12px;
    color: var(--fade);
    font-size: 16px;
    letter-spacing: 2px;
    font-style: italic;
  }
  .header-line {
    width: 80px; height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 20px auto;
  }

  /* SEARCH & FILTER */
  .controls {
    max-width: 900px;
    margin: 30px auto 0;
    padding: 0 20px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }
  .search-box {
    flex: 1; min-width: 200px; max-width: 340px;
    display: flex;
    align-items: center;
    background: white;
    border: 1px solid rgba(139,115,85,0.3);
    border-radius: 4px;
    padding: 8px 14px;
    gap: 8px;
  }
  .search-box input {
    border: none; outline: none;
    font-family: inherit; font-size: 15px;
    background: transparent; width: 100%;
    color: var(--ink);
  }
  .search-box input::placeholder { color: var(--fade); }
  .filter-btns {
    display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;
  }
  .filter-btn {
    padding: 7px 16px;
    border: 1px solid rgba(139,115,85,0.35);
    background: transparent;
    border-radius: 3px;
    cursor: pointer;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 13px;
    color: var(--fade);
    transition: all 0.2s;
    letter-spacing: 0.5px;
  }
  .filter-btn:hover, .filter-btn.active {
    background: var(--brush);
    color: var(--paper);
    border-color: var(--brush);
  }

  /* MAIN GRID */
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px 80px;
  }

  .group-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 13px;
    letter-spacing: 4px;
    color: var(--gold);
    text-transform: uppercase;
    margin: 50px 0 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .group-title::before, .group-title::after {
    content: '';
    flex: 1; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(184,134,11,0.3), transparent);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  /* CARD */
  .card {
    background: white;
    border: 1px solid rgba(139,115,85,0.18);
    border-radius: 6px;
    overflow: hidden;
    transition: all 0.25s ease;
    cursor: pointer;
    position: relative;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(44,24,16,0.1);
    border-color: rgba(184,134,11,0.4);
  }
  .card.hidden { display: none; }

  .card-top {
    background: linear-gradient(135deg, var(--brush) 0%, #3d2010 100%);
    padding: 28px 20px 20px;
    display: flex;
    align-items: center;
    gap: 20px;
    position: relative;
    overflow: hidden;
  }
  .card-top::before {
    content: attr(data-char);
    position: absolute;
    right: -10px; top: -20px;
    font-family: 'Noto Serif SC', serif;
    font-size: 100px;
    color: rgba(255,255,255,0.04);
    pointer-events: none;
  }

  .char-display {
    font-family: 'Noto Serif SC', serif;
    font-size: 64px;
    color: white;
    line-height: 1;
    text-shadow: 2px 4px 12px rgba(0,0,0,0.4);
    min-width: 70px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .char-meta { position: relative; z-index: 1; }
  .char-pinyin {
    font-size: 18px;
    color: var(--gold-light);
    letter-spacing: 2px;
    font-style: italic;
  }
  .char-hanviet {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 1px;
    margin-top: 4px;
    text-transform: uppercase;
  }
  .char-meaning {
    font-size: 20px;
    color: rgba(255,255,255,0.9);
    margin-top: 6px;
    font-weight: 300;
  }

  .audio-btn {
    margin-left: auto;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.08);
    color: white;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
    font-size: 14px;
    position: relative; z-index: 1;
    flex-shrink: 0;
  }
  .audio-btn:hover {
    background: rgba(184,134,11,0.3);
    border-color: var(--gold-light);
  }
  .audio-btn.playing {
    background: var(--gold);
    border-color: var(--gold);
    animation: pulse 0.8s infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .card-body {
    padding: 18px 20px;
  }

  /* VISUAL */
  .visual-box {
    background: var(--paper);
    border: 1px solid rgba(139,115,85,0.15);
    border-radius: 4px;
    padding: 14px 16px;
    margin-bottom: 14px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .visual-icon {
    font-size: 28px;
    flex-shrink: 0;
    line-height: 1.2;
  }
  .visual-text {
    font-size: 13.5px;
    color: var(--fade);
    line-height: 1.6;
    font-style: italic;
  }
  .visual-text strong { color: var(--ink); font-style: normal; }

  /* EXAMPLES */
  .examples-label {
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 8px;
    font-family: 'Noto Sans SC', sans-serif;
  }
  .examples-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }
  .example-tag {
    background: var(--paper2);
    border: 1px solid rgba(139,115,85,0.2);
    border-radius: 3px;
    padding: 4px 10px;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .example-tag .ex-char {
    font-family: 'Noto Serif SC', serif;
    font-size: 16px;
    color: var(--brush);
  }
  .example-tag .ex-info {
    font-size: 11px;
    color: var(--fade);
    line-height: 1.3;
  }

  /* USAGE NOTE */
  .usage-note {
    font-size: 13px;
    color: #5a4a3a;
    line-height: 1.65;
    border-left: 2px solid rgba(184,134,11,0.4);
    padding-left: 10px;
  }

  /* GROUP TAG */
  .group-tag {
    position: absolute;
    top: 10px; right: 10px;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    font-family: 'Noto Sans SC', sans-serif;
  }

  /* STROKE ORDER HINT */
  .stroke-hint {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid rgba(139,115,85,0.12);
    font-size: 12px;
    color: var(--fade);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* COUNT */
  .results-count {
    text-align: center;
    font-size: 13px;
    color: var(--fade);
    margin-top: -10px;
    margin-bottom: 20px;
    letter-spacing: 1px;
  }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 30px;
    border-top: 1px solid rgba(139,115,85,0.15);
    color: var(--fade);
    font-size: 13px;
    letter-spacing: 1px;
  }

  @media (max-width: 600px) {
    .cards-grid { grid-template-columns: 1fr; }
    .char-display { font-size: 52px; }
  }
</style>
</head>
<body>

<header>
  <h1>百 <span>部</span> 首</h1>
  <p>100 Bộ Thủ Hán Tự — Nền Tảng Nhận Diện Chữ Hán</p>
  <div class="header-line"></div>
  <div class="controls">
    <div class="search-box">
      <span>🔍</span>
      <input type="text" id="searchInput" placeholder="Tìm bộ thủ, âm HV, nghĩa...">
    </div>
    <div class="filter-btns">
      <button class="filter-btn active" data-group="all">Tất cả</button>
      <button class="filter-btn" data-group="thien-nhien">Thiên nhiên</button>
      <button class="filter-btn" data-group="con-nguoi">Con người</button>
      <button class="filter-btn" data-group="dong-vat">Động vật</button>
      <button class="filter-btn" data-group="nha-cua">Nhà cửa</button>
      <button class="filter-btn" data-group="hanh-dong">Hành động</button>
      <button class="filter-btn" data-group="khong-gian">Không gian</button>
      <button class="filter-btn" data-group="so-luong">Số lượng</button>
      <button class="filter-btn" data-group="mau-sac">Màu sắc</button>
      <button class="filter-btn" data-group="mo-rong">Mở rộng</button>
    </div>
  </div>
</header>

<main id="mainContent">
  <div class="results-count" id="resultsCount">Hiển thị 100 bộ thủ</div>
</main>

<footer>
  <p>Phương pháp học theo Chris Lonsdale — Direct Connect · Brain Soaking · Comprehensible Input</p>
</footer>

