// Render
function renderAll(filter = 'all', search = '') {
  const main = document.getElementById('mainContent');
  const countEl = document.getElementById('resultsCount');
  // Remove old groups
  document.querySelectorAll('.group-section').forEach(e => e.remove());

  const groups = {
    'thien-nhien': 'Thiên Nhiên',
    'con-nguoi': 'Con Người & Cơ Thể',
    'dong-vat': 'Động Vật',
    'nha-cua': 'Nhà Cửa & Vật Dụng',
    'hanh-dong': 'Hành Động & Trạng Thái',
    'khong-gian': 'Không Gian & Phương Hướng',
    'so-luong': 'Số & Lượng',
    'mau-sac': 'Màu Sắc & Giác Quan',
    'mo-rong': 'Tự Nhiên Mở Rộng'
  };

  let totalShown = 0;
  const searchLower = search.toLowerCase();

  Object.entries(groups).forEach(([gKey, gLabel]) => {
    if (filter !== 'all' && filter !== gKey) return;
    const items = radicals.filter(r => {
      if (r.group !== gKey) return false;
      if (!search) return true;
      return r.char.includes(search) ||
        r.pinyin.toLowerCase().includes(searchLower) ||
        r.hanviet.toLowerCase().includes(searchLower) ||
        r.meaning.toLowerCase().includes(searchLower);
    });
    if (items.length === 0) return;
    totalShown += items.length;

    const section = document.createElement('div');
    section.className = 'group-section';

    const title = document.createElement('div');
    title.className = 'group-title';
    title.textContent = gLabel;
    section.appendChild(title);

    const grid = document.createElement('div');
    grid.className = 'cards-grid';

    items.forEach(r => {
      const card = document.createElement('div');
      card.className = 'card';

      const examplesHtml = r.examples.map(e =>
        `<div class="example-tag">
          <span class="ex-char">${e.char}</span>
          <span class="ex-info">${e.pinyin}<br>${e.vi}</span>
        </div>`
      ).join('');

      card.innerHTML = `
        <div class="card-top" data-char="${r.char}">
          <span class="group-tag">${r.group.replace('-',' ')}</span>
          <div class="char-display">${r.char}</div>
          <div class="char-meta">
            <div class="char-pinyin">${r.pinyin}</div>
            <div class="char-hanviet">${r.hanviet}</div>
            <div class="char-meaning">${r.meaning}</div>
          </div>
          <button class="audio-btn" title="Nghe phát âm" onclick="speak('${r.char}', '${r.pinyin}', this)">🔊</button>
        </div>
        <div class="card-body">
          <div class="visual-box">
            <span class="visual-icon">${r.icon}</span>
            <div class="visual-text">${r.visual}</div>
          </div>
          <div class="examples-label">Ví dụ thực tế</div>
          <div class="examples-list">${examplesHtml}</div>
          <div class="examples-label">Cách dùng</div>
          <div class="usage-note">${r.usage}</div>
        </div>
      `;
      grid.appendChild(card);
    });

    section.appendChild(grid);
    main.appendChild(section);
  });

  countEl.textContent = `Hiển thị ${totalShown} bộ thủ`;
}

// Speech
function speak(char, pinyin, btn) {
  if ('speechSynthesis' in window) {
    window.speechSynthesis.cancel();
    const utter = new SpeechSynthesisUtterance(char);
    utter.lang = 'zh-CN';
    utter.rate = 0.8;
    btn.classList.add('playing');
    utter.onend = () => btn.classList.remove('playing');
    utter.onerror = () => btn.classList.remove('playing');
    window.speechSynthesis.speak(utter);
  } else {
    // Fallback: open TTS link
    window.open(`https://translate.google.com/?sl=zh-CN&tl=vi&text=${encodeURIComponent(char)}&op=translate`, '_blank');
  }
}

// Filter buttons
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderAll(btn.dataset.group, document.getElementById('searchInput').value);
  });
});

// Search
let searchTimer;
document.getElementById('searchInput').addEventListener('input', e => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    const activeFilter = document.querySelector('.filter-btn.active')?.dataset.group || 'all';
    renderAll(activeFilter, e.target.value);
  }, 300);
});

// Init
renderAll();
